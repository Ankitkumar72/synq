rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Base user document for plan streams
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Only backend can set plan_tier
    }

    match /users/{userId}/notes/{noteId} {
      allow read, write: if request.auth != null 
                        && request.auth.uid == userId;
    }
    match /users/{userId}/folders/{folderId} {
      allow read, write: if request.auth != null 
                        && request.auth.uid == userId;
    }
    
    // Paddle webhook storage
    match /paddle_transactions/{document=**} {
      allow read, write: if false; // Only backend can access
    }
}
